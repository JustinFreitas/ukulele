# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly declare text files to always use LF
*.kt text eol=lf
*.kts text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
.gitignore text eol=lf
Dockerfile text eol=lf
ukulele text eol=lf

# Denote binary files to prevent normalization
*.jar binary
*.db binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
